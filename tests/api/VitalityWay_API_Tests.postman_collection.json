    {
      "name": "Teste de API 3 - Agendamento (POST /consultas)",
      "item": [
        {
          "name": "CT01 - Agendamento válido",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test(\"Status code deve ser 201\", function () {",
            "    pm.response.to.have.status(201);",
            "});",
            "pm.test(\"Mensagem: Consulta agendada com sucesso\", function () {",
            "    var json = pm.response.json();",
            "    pm.expect(json.mensagem).to.eql(\"Consulta agendada com sucesso\");",
            "});",
            "pm.test(\"Status da consulta é agendada\", function () {",
            "    var json = pm.response.json();",
            "    pm.expect(json.dados.status).to.eql(\"agendada\");",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/consultas",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"idosoId\": \"i1\",\n  \"medicoId\": \"m1\",\n  \"data\": \"2026-07-10\",\n  \"hora\": \"14:30\",\n  \"local\": \"UBS Centro\"\n}" }
          }
        },
