{
  "info": {
    "name": "VitalityWay - Testes de API",
    "_postman_id": "vitalityway-tests-2026",
    "description": "Coleção de testes de API para o sistema VitalityWay",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Teste de API 1 - Login (POST /login)",
      "item": [
        {
          "name": "CT01 - Login válido",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test(\"Status code deve ser 200\", function () {",
            "    pm.response.to.have.status(200);",
            "});",
            "pm.test(\"Mensagem de sucesso\", function () {",
            "    var json = pm.response.json();",
            "    pm.expect(json.mensagem).to.eql(\"Login realizado com sucesso\");",
            "});",
            "pm.test(\"Resposta contém token\", function () {",
            "    var json = pm.response.json();",
            "    pm.expect(json.dados).to.have.property(\"token\");",
            "    pm.collectionVariables.set(\"token\", json.dados.token);",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"cuidador@email.com\",\n  \"senha\": \"12345678\"\n}" }
          }
        },
        {
          "name": "CT02 - E-mail vazio",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test(\"Status code deve ser 400\", function () {",
            "    pm.response.to.have.status(400);",
            "});",
            "pm.test(\"Mensagem: E-mail obrigatório\", function () {",
            "    var json = pm.response.json();",
            "    pm.expect(json.mensagem).to.eql(\"E-mail obrigatório\");",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"\",\n  \"senha\": \"12345678\"\n}" }
          }
        },
        {
          "name": "CT03 - E-mail inválido (sem @)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test(\"Status code deve ser 400\", function () {",
            "    pm.response.to.have.status(400);",
            "});",
            "pm.test(\"Mensagem: E-mail inválido\", function () {",
            "    var json = pm.response.json();",
            "    pm.expect(json.mensagem).to.eql(\"E-mail inválido\");",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"naoehmail\",\n  \"senha\": \"12345678\"\n}" }
          }
        },
        {
          "name": "CT04 - Senha vazia",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test(\"Status code deve ser 400\", function () {",
            "    pm.response.to.have.status(400);",
            "});",
            "pm.test(\"Mensagem: Senha obrigatória\", function () {",
            "    var json = pm.response.json();",
            "    pm.expect(json.mensagem).to.eql(\"Senha obrigatória\");",
