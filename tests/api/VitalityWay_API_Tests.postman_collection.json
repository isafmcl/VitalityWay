    {
      "name": "Teste de API 2 - Cadastro de Médico (POST /medicos)",
      "item": [
        {
          "name": "CT01 - Cadastro válido",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test(\"Status code deve ser 201\", function () {",
            "    pm.response.to.have.status(201);",
            "});",
