            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Dr. Paulo Sauro\",\n  \"crm\": \"777888\",\n  \"especialidadeId\": \"e1\"\n}" }
